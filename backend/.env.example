APP_NAME=AI Career Recommendation API
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Local: * (allow all)
# Production: set to your GitHub Pages URL, e.g. https://yourusername.github.io
CORS_ORIGINS=*

# --- Databases (local Docker defaults) ---
POSTGRES_URL=postgresql://postgres:postgres@db:5432/career_db
MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=career_platform

# --- Production DB examples (uncomment and fill in) ---
